# Copy this file to .env and fill in your values
# NEVER commit .env to git

GROQ_API_KEY=your_groq_api_key_here

# How many posts to react+comment on per run
MAX_POSTS=5

# Gap between posts in seconds (randomized between min/max) so activity
# doesn't look bursty/spammy to LinkedIn
MIN_GAP_SECONDS=50
MAX_GAP_SECONDS=90

# true = run Chrome without a visible window (set false while debugging)
HEADLESS=false

# Skip posts older than this (hours) — no point reacting/commenting on a
# post the algorithm has stopped pushing to anyone's feed.
MAX_POST_AGE_HOURS=12

# Used only by linkedin_watcher_cybrum.py — the exact Page name shown in
# LinkedIn's "Comment, react, and repost as" dialog to switch engagement to.
ENGAGE_AS_PAGE=Cybrum Solutions
