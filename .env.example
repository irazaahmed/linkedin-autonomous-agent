# Copy this file to .env and fill in your values
# NEVER commit .env to git

GROQ_API_KEY=your_groq_api_key_here

# How many posts to react+comment on per run
MAX_POSTS=5

# Gap between posts in seconds (randomized between min/max) so activity
# doesn't look bursty/spammy to LinkedIn
MIN_GAP_SECONDS=50
MAX_GAP_SECONDS=90

# true = run Chrome without a visible window (set false while debugging)
HEADLESS=false

# Comma-separated LinkedIn hashtags (no #) to target instead of the home feed.
# Leave empty to scan the algorithmic home feed (old behavior).
TARGET_HASHTAGS=artificialintelligence,ai,machinelearning,generativeai,genai,llm,chatgpt,claude,claudecode,gemini,openai,agenticai,aiagents,automation,rpa,nocode,entrepreneur,startups,futureofwork,digitaltransformation,innovation,techstartup
